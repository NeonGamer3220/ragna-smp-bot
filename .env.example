# Required
DISCORD_TOKEN=

# Supabase
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Optional — slash command(s) guild-synced instantly if set
GUILD_ID=

# Optional — log channel for application reviews (default: 1504913411010461938)
LOG_CHANNEL_ID=1504913411010461938

# Optional — channel where /teamcreate can be used (default: 1505117200522936380)
TEAM_CREATE_CH=1505117200522936380

# Optional — role required to use /teamcreate (default: 1504866162713039002)
TEAM_CREATE_ROLE=1504866162713039002

# Optional — Discord user IDs for admin commands (comma-separated)
# Needed for: /tournament, /teamdelete, /teamleader, queue accept/reject
ADMIN_IDS=
